{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "iDempiere Extension Metadata",
  "type": "object",
  "required": ["id", "name", "version", "idempiereVersion", "bundles"],
  "properties": {
    "id": {
      "type": "string",
      "description": "The unique identifier for the extension (usually the symbolic name)."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(\\.[a-zA-Z0-9_-]+)?$",
      "description": "OSGi versioning string (e.g., 1.0.0, 1.0.0.20260331)."
    },
    "idempiereVersion": {
      "type": "string",
      "description": "The major version of iDempiere supported (e.g., '11' or '12')."
    },
    "releaseDate": {
      "type": "string",
      "format": "date",
      "description": "The date of the release in YYYY-MM-DD format."
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "categories": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "entityType": {
      "type": "string",
      "description": "Identifies the type of entity, often matching the ID or a specific extension class."
    },
    "bundles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["symbolicName"],
        "properties": {
          "symbolicName": { "type": "string" },
          "downloadUrl": { "type": "string", "format": "uri" },
          "sha256": { "type": "string" }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "version"],
        "properties": {
          "id": { "type": "string" },
          "version": { "type": "string" }
        }
      }
    },
    "database": {
       "type": "array",
       "items": {
         "type": "object",
         "required": ["id"],
         "properties": {
           "id": { "type": "string" },
           "version": { "type": "string" },
           "extensions": {
              "type": "array",
              "items": {
	         "type": "string"
              }
           }
         } 
       }
    }
  }
}
